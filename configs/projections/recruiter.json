{
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "omit",
  "fields": [
    {
      "path": "name",
      "from": "full_name",
      "type": "string",
      "required": true
    },
    {
      "path": "primary_email",
      "from": "contact.emails[0]",
      "type": "string",
      "normalize": "lowercase"
    },
    {
      "path": "primary_phone",
      "from": "contact.phones[0]",
      "type": "string",
      "normalize": "E164"
    },
    {
      "path": "recent_employer",
      "from": "experience[0].company",
      "type": "string",
      "normalize": "canonical"
    },
    {
      "path": "recent_title",
      "from": "experience[0].title",
      "type": "string",
      "normalize": "canonical"
    }
  ]
}
