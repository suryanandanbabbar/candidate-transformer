{
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "omit",
  "fields": [
    {
      "path": "name",
      "from": "full_name",
      "type": "string",
      "required": true
    },
    {
      "path": "primary_email",
      "from": "contact.emails[0]",
      "type": "string",
      "normalize": "lowercase"
    },
    {
      "path": "primary_phone",
      "from": "contact.phones[0]",
      "type": "string",
      "normalize": "E164"
    },
    {
      "path": "recent_employer",
      "from": "experience[0].company",
      "type": "string",
      "normalize": "canonical"
    },
    {
      "path": "recent_title",
      "from": "experience[0].title",
      "type": "string",
      "normalize": "canonical"
    }
  ],
  "display": {
    "title": "Recruiter Projection",
    "overview_columns": [
      {
        "header": "Name",
        "path": "name"
      },
      {
        "header": "Primary Email",
        "path": "primary_email"
      },
      {
        "header": "Primary Phone",
        "path": "primary_phone"
      },
      {
        "header": "Recent Employer",
        "path": "recent_employer"
      },
      {
        "header": "Recent Title",
        "path": "recent_title"
      }
    ],
    "detail_sections": [
      {
        "title": "Candidate",
        "fields": [
          {
            "label": "Name",
            "path": "name"
          },
          {
            "label": "Primary Email",
            "path": "primary_email"
          },
          {
            "label": "Primary Phone",
            "path": "primary_phone"
          }
        ]
      },
      {
        "title": "Recent Experience",
        "fields": [
          {
            "label": "Employer",
            "path": "recent_employer"
          },
          {
            "label": "Title",
            "path": "recent_title"
          }
        ]
      }
    ]
  }
}